<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>ProdOps Bot — {{ topic }}</title>
<style>
  :root {
    --bg: #F5F7FB;
    --card: #FFFFFF;
    --ink: #0F1B2E;
    --ink-soft: #4C5A72;
    --ink-mute: #7A8699;
    --border: #E4E9F2;
    --shadow: 0 2px 4px rgba(15,27,46,.04), 0 8px 24px rgba(15,27,46,.06);

    /* Lane color families — pale fill + saturated title bar */
    --lane-blue-bg:   #EFF6FF; --lane-blue-bar:   #2563EB; --lane-blue-node:  #DBEAFE;
    --lane-green-bg:  #F0FDF4; --lane-green-bar:  #16A34A; --lane-green-node: #DCFCE7;
    --lane-orange-bg: #FFF7ED; --lane-orange-bar: #EA580C; --lane-orange-node:#FFEDD5;
    --lane-purple-bg: #F5F3FF; --lane-purple-bar: #7C3AED; --lane-purple-node:#EDE9FE;
    --lane-teal-bg:   #F0FDFA; --lane-teal-bar:   #0D9488; --lane-teal-node:  #CCFBF1;
    --lane-slate-bg:  #F8FAFC; --lane-slate-bar:  #475569; --lane-slate-node: #E2E8F0;

    --sev-red: #DC2626;      --sev-red-bg: #FEE2E2;
    --sev-green: #16A34A;    --sev-green-bg: #DCFCE7;
    --sev-amber: #D97706;    --sev-amber-bg: #FEF3C7;
    --sev-indigo: #4F46E5;   --sev-indigo-bg: #EEF2FF;
    --sev-slate: #475569;    --sev-slate-bg: #E2E8F0;
    --sev-purple: #7C3AED;   --sev-purple-bg: #EDE9FE;
  }

  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg); color: var(--ink);
    -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;
  }

  .page { width: 1400px; padding: 48px; }

  /* ---------- Header ---------- */
  .header {
    background: var(--card); border: 1px solid var(--border); border-radius: 16px;
    padding: 28px 32px; box-shadow: var(--shadow); margin-bottom: 24px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .header-left { display: flex; gap: 20px; align-items: center; }
  .header-icon {
    width: 64px; height: 64px; border-radius: 14px;
    background: linear-gradient(135deg, #7C3AED 0%, #4F46E5 100%);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 32px; flex-shrink: 0;
  }
  .header-text { display: flex; flex-direction: column; gap: 6px; }
  .kind-tag {
    font-size: 13px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--sev-indigo);
  }
  .topic { font-size: 24px; font-weight: 700; color: var(--ink); line-height: 1.25; max-width: 900px; }
  .question { font-size: 14px; color: var(--ink-mute); margin-top: 4px; max-width: 950px; line-height: 1.4; }
  .question b { color: var(--ink-soft); font-weight: 600; }
  .header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
  .pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: 999px;
    font-size: 12px; font-weight: 600; line-height: 1;
  }
  .pill.intent            { background: var(--sev-purple-bg); color: var(--sev-purple); }
  .pill.confidence-high   { background: var(--sev-green-bg); color: var(--sev-green); }
  .pill.confidence-medium { background: var(--sev-amber-bg); color: var(--sev-amber); }
  .pill.confidence-low    { background: var(--sev-red-bg);   color: var(--sev-red); }

  /* ---------- TL;DR ---------- */
  .tldr {
    background: linear-gradient(135deg, #EEF2FF 0%, #F0FDF4 100%);
    border: 1px solid #C7D2FE; border-radius: 16px;
    padding: 22px 26px; margin-bottom: 24px; box-shadow: var(--shadow);
    display: flex; align-items: flex-start; gap: 16px;
  }
  .tldr-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--sev-indigo); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
  }
  .tldr-body { flex: 1; }
  .tldr-label {
    font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--sev-indigo); margin-bottom: 4px;
  }
  .tldr-text { font-size: 17px; font-weight: 600; color: var(--ink); line-height: 1.4; }

  /* ---------- Workflow body: grid with optional side column ---------- */
  .workflow-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  .workflow-body.with-side { grid-template-columns: 1fr 340px; }

  .lanes-column { display: flex; flex-direction: column; gap: 18px; }
  .side-column  { display: flex; flex-direction: column; gap: 18px; }

  /* ---------- Lane ---------- */
  .lane {
    border-radius: 14px; overflow: hidden;
    background: var(--card); border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  .lane.blue   { background: var(--lane-blue-bg);   border-color: #BFDBFE; }
  .lane.green  { background: var(--lane-green-bg);  border-color: #BBF7D0; }
  .lane.orange { background: var(--lane-orange-bg); border-color: #FED7AA; }
  .lane.purple { background: var(--lane-purple-bg); border-color: #DDD6FE; }
  .lane.teal   { background: var(--lane-teal-bg);   border-color: #99F6E4; }
  .lane.slate  { background: var(--lane-slate-bg);  border-color: #CBD5E1; }

  .lane-title {
    padding: 12px 20px; font-size: 15px; font-weight: 700;
    letter-spacing: .02em; color: #fff; display: flex; align-items: center; gap: 10px;
  }
  .lane.blue   .lane-title { background: var(--lane-blue-bar); }
  .lane.green  .lane-title { background: var(--lane-green-bar); }
  .lane.orange .lane-title { background: var(--lane-orange-bar); }
  .lane.purple .lane-title { background: var(--lane-purple-bar); }
  .lane.teal   .lane-title { background: var(--lane-teal-bar); }
  .lane.slate  .lane-title { background: var(--lane-slate-bar); }

  .lane-nodes {
    display: flex; align-items: stretch; justify-content: center;
    gap: 4px; padding: 20px 20px 14px; flex-wrap: nowrap;
  }
  .lane.rtl .lane-nodes { flex-direction: row-reverse; }

  /* ---------- Node ---------- */
  .node {
    background: var(--card); border: 1.5px solid var(--border);
    border-radius: 12px; padding: 12px 14px; min-width: 130px; max-width: 200px;
    display: flex; flex-direction: column; gap: 6px; align-items: center; text-align: center;
    box-shadow: 0 1px 2px rgba(15,27,46,.04);
  }
  .lane.blue   .node { border-color: #93C5FD; background: #fff; }
  .lane.green  .node { border-color: #86EFAC; background: #fff; }
  .lane.orange .node { border-color: #FDBA74; background: #fff; }
  .lane.purple .node { border-color: #C4B5FD; background: #fff; }
  .lane.teal   .node { border-color: #5EEAD4; background: #fff; }
  .lane.slate  .node { border-color: #94A3B8; background: #fff; }

  .node-icon {
    width: 40px; height: 40px; border-radius: 8px;
    background: var(--lane-slate-node); color: var(--sev-slate);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; flex-shrink: 0;
  }
  .lane.blue   .node-icon { background: var(--lane-blue-node);   color: var(--lane-blue-bar); }
  .lane.green  .node-icon { background: var(--lane-green-node);  color: var(--lane-green-bar); }
  .lane.orange .node-icon { background: var(--lane-orange-node); color: var(--lane-orange-bar); }
  .lane.purple .node-icon { background: var(--lane-purple-node); color: var(--lane-purple-bar); }
  .lane.teal   .node-icon { background: var(--lane-teal-node);   color: var(--lane-teal-bar); }

  .node-title { font-size: 13.5px; font-weight: 700; color: var(--ink); line-height: 1.25; }
  .node-sub   { font-size: 11.5px; color: var(--ink-mute); line-height: 1.3; }

  .node-chip {
    display: flex; align-items: center; gap: 6px;
    background: #F1F5F9; border: 1px solid var(--border); border-radius: 8px;
    padding: 6px 8px; margin-top: 6px; width: 100%;
    font-size: 11px; color: var(--ink-soft); text-align: left;
  }
  .node-chip.key   { background: #FEF3C7; border-color: #FDE68A; color: #92400E; }
  .node-chip.pubkey{ background: #EDE9FE; border-color: #DDD6FE; color: #6D28D9; }
  .node-chip .chip-icon { flex-shrink: 0; font-size: 13px; }
  .node-chip .chip-text { flex: 1; line-height: 1.3; }
  .node-chip .chip-text b { color: inherit; font-weight: 700; }

  /* ---------- Arrow ---------- */
  .arrow {
    align-self: center;
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    color: var(--ink-mute); flex-shrink: 0; min-width: 40px;
  }
  .arrow-line {
    font-size: 22px; line-height: 1; font-weight: 700; color: var(--ink-soft);
  }
  .arrow-label {
    font-size: 10.5px; font-weight: 600; color: var(--ink-soft);
    background: var(--card); border: 1px solid var(--border);
    padding: 2px 6px; border-radius: 4px;
    max-width: 100px; text-align: center; line-height: 1.2;
  }

  /* ---------- Lane footer (tag row) ---------- */
  .lane-footer {
    padding: 0 20px 14px; display: flex; flex-wrap: wrap; gap: 8px;
    font-size: 11px; color: var(--ink-soft);
  }
  .lane-footer-label {
    font-weight: 700; letter-spacing: .04em; text-transform: uppercase;
    color: var(--ink-mute); font-size: 10.5px; margin-right: 4px; align-self: center;
  }
  .tag {
    display: inline-flex; align-items: center; gap: 4px;
    background: rgba(255,255,255,.7); border: 1px solid var(--border);
    padding: 3px 8px; border-radius: 6px;
    font-family: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
    font-size: 11px; color: var(--ink-soft);
  }

  /* ---------- Side column: info box ---------- */
  .info-box {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; overflow: hidden; box-shadow: var(--shadow);
  }
  .info-box.blue   { border-color: #BFDBFE; }
  .info-box.green  { border-color: #BBF7D0; }
  .info-box.orange { border-color: #FED7AA; }
  .info-box.purple { border-color: #DDD6FE; }
  .info-box.teal   { border-color: #99F6E4; }

  .info-title {
    padding: 12px 16px; font-size: 14px; font-weight: 700; color: #fff;
    background: var(--sev-slate);
  }
  .info-box.blue   .info-title { background: var(--lane-blue-bar); }
  .info-box.green  .info-title { background: var(--lane-green-bar); }
  .info-box.orange .info-title { background: var(--lane-orange-bar); }
  .info-box.purple .info-title { background: var(--lane-purple-bar); }
  .info-box.teal   .info-title { background: var(--lane-teal-bar); }

  .info-items { display: flex; flex-direction: column; gap: 10px; padding: 14px; }
  .info-item {
    display: flex; gap: 10px; align-items: flex-start;
    padding: 10px 12px; background: #F8FAFC; border: 1px solid var(--border);
    border-radius: 10px;
  }
  .info-item-icon {
    width: 32px; height: 32px; border-radius: 8px;
    background: var(--lane-purple-node); color: var(--lane-purple-bar);
    display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0;
  }
  .info-box.blue   .info-item-icon { background: var(--lane-blue-node);   color: var(--lane-blue-bar); }
  .info-box.green  .info-item-icon { background: var(--lane-green-node);  color: var(--lane-green-bar); }
  .info-box.orange .info-item-icon { background: var(--lane-orange-node); color: var(--lane-orange-bar); }
  .info-box.teal   .info-item-icon { background: var(--lane-teal-node);   color: var(--lane-teal-bar); }

  .info-item-body { flex: 1; }
  .info-item-title { font-size: 13px; font-weight: 600; color: var(--ink); line-height: 1.3; }
  .info-item-sub   { font-size: 11.5px; color: var(--ink-mute); margin-top: 2px; line-height: 1.35; }

  /* ---------- Legend box ---------- */
  .legend-box {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; padding: 14px 16px; box-shadow: var(--shadow);
  }
  .legend-title {
    font-size: 12px; font-weight: 700; letter-spacing: .06em;
    text-transform: uppercase; color: var(--ink-soft); margin-bottom: 10px;
  }
  .legend-items { display: flex; flex-direction: column; gap: 8px; }
  .legend-item {
    display: flex; gap: 10px; align-items: flex-start;
    font-size: 12px; color: var(--ink-soft); line-height: 1.4;
  }
  .legend-icon {
    width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 13px;
    background: var(--lane-slate-node); color: var(--sev-slate);
  }
  .legend-item.key    .legend-icon { background: #FEF3C7; color: #92400E; }
  .legend-item.pubkey .legend-icon { background: #EDE9FE; color: #6D28D9; }

  /* ---------- Shared: source badges (facts / sources sections) ---------- */
  .source-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--sev-indigo-bg); color: var(--sev-indigo);
    font-size: 11.5px; font-weight: 600;
    padding: 4px 10px; border-radius: 6px; border: 1px solid #E0E7FF;
  }
  .source-badge.jira      { background: #FEF3C7; color: #B45309; border-color: #FDE68A; }
  .source-badge.slack     { background: #FCE7F3; color: #BE185D; border-color: #FBCFE8; }
  .source-badge.confluence{ background: #EEF2FF; color: #4338CA; border-color: #E0E7FF; }
  .source-badge.repo      { background: #E2E8F0; color: #334155; border-color: #CBD5E1; }
  .source-badge.unverified{ background: var(--sev-amber-bg); color: var(--sev-amber); border-color: #FCD34D; }
  .source-badge .dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

  /* ---------- Footer sections (sources / confidence / for-you) ---------- */
  .section {
    background: var(--card); border: 1px solid var(--border); border-radius: 14px;
    padding: 20px 22px; box-shadow: var(--shadow); margin-bottom: 16px;
    position: relative; overflow: hidden;
  }
  .section::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 5px;
  }
  .section.sources::before    { background: var(--sev-slate); }
  .section.confidence::before { background: var(--sev-amber); }
  .section.foryou::before     { background: var(--sev-green); }

  .section-head { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .section-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;
  }
  .section.sources    .section-icon { background: var(--sev-slate-bg);  color: var(--sev-slate); }
  .section.confidence .section-icon { background: var(--sev-amber-bg);  color: var(--sev-amber); }
  .section.foryou     .section-icon { background: var(--sev-green-bg);  color: var(--sev-green); }
  .section-title { font-size: 16px; font-weight: 700; color: var(--ink); }
  .section-sub   { font-size: 12px; color: var(--ink-mute); margin-top: 2px; }

  .sources-groups { display: flex; flex-direction: column; gap: 10px; }
  .sources-group {
    padding: 10px 12px; background: #F8FAFC; border: 1px solid var(--border); border-radius: 10px;
  }
  .sources-group-title {
    font-size: 11.5px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
    color: var(--ink-soft); margin-bottom: 6px;
  }
  .source-item { font-size: 13px; color: var(--ink); line-height: 1.5; padding: 2px 0; }
  .source-item b { color: var(--ink); font-weight: 600; }
  .source-item .meta { color: var(--ink-mute); font-size: 11.5px; }

  .conf-card {
    display: flex; gap: 16px; align-items: center;
  }
  .conf-level {
    padding: 8px 14px; border-radius: 10px; font-size: 14px; font-weight: 700;
    display: inline-flex; align-items: center; gap: 8px; flex-shrink: 0;
  }
  .conf-level.high   { background: var(--sev-green-bg); color: var(--sev-green); }
  .conf-level.medium { background: var(--sev-amber-bg); color: var(--sev-amber); }
  .conf-level.low    { background: var(--sev-red-bg);   color: var(--sev-red); }
  .conf-detail { flex: 1; font-size: 13px; color: var(--ink-soft); line-height: 1.5; }
  .conf-detail b { color: var(--ink); font-weight: 600; }
  .conf-detail .not-verified {
    display: block; margin-top: 6px; padding: 6px 10px;
    background: #FEF3C7; border-left: 3px solid var(--sev-amber);
    color: #92400E; font-size: 12.5px; border-radius: 4px;
  }

  .foryou-list { display: flex; flex-direction: column; gap: 8px; }
  .foryou-item {
    display: flex; gap: 10px; align-items: flex-start;
    padding: 10px 12px; background: #F6FBF3; border: 1px solid #DCFCE7; border-radius: 10px;
  }
  .foryou-check {
    width: 22px; height: 22px; border-radius: 50%; margin-top: 1px;
    background: var(--sev-green); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; flex-shrink: 0;
  }
  .foryou-item.recommend .foryou-check { background: var(--sev-indigo); }
  .foryou-item.recommend { background: #F5F3FF; border-color: #DDD6FE; }
  .foryou-text { font-size: 13.5px; color: var(--ink); line-height: 1.5; }
  .foryou-text b { color: var(--ink); font-weight: 600; }

  code {
    font-family: 'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace;
    font-size: 12px; background: #F1F3F8; color: #1E293B;
    padding: 1px 5px; border-radius: 4px; border: 1px solid #E2E8F0;
  }

  .footer {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 18px; background: var(--card); border: 1px solid var(--border);
    border-radius: 12px; font-size: 12px; color: var(--ink-mute);
  }
  .footer .brand { display: flex; align-items: center; gap: 8px; font-weight: 600; color: var(--ink-soft); }
  .footer .brand-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--sev-indigo); }
</style>
</head>
<body>
<div class="page">

  {# =========================================================
     HEADER
     ========================================================= #}
  <div class="header">
    <div class="header-left">
      <div class="header-icon">🤖</div>
      <div class="header-text">
        <div class="kind-tag">Knowledge answer{% if kind is defined and kind %} · {{ kind }}{% endif %}</div>
        <div class="topic">{{ topic }}</div>
        {% if question is defined and question %}<div class="question">🗨️ <b>Question:</b> {{ question|safe }}</div>{% endif %}
      </div>
    </div>
    <div class="header-right">
      <span class="pill intent">● knowledge_query · workflow</span>
      {% if confidence is defined and confidence and confidence.level is defined and confidence.level %}
        <span class="pill confidence-{{ confidence.level|lower }}">📊 Confidence · {{ confidence.level }}</span>
      {% endif %}
    </div>
  </div>

  {# =========================================================
     TL;DR
     ========================================================= #}
  {% if tldr is defined and tldr %}
  <div class="tldr">
    <div class="tldr-icon">💡</div>
    <div class="tldr-body">
      <div class="tldr-label">TL;DR</div>
      <div class="tldr-text">{{ tldr|safe }}</div>
    </div>
  </div>
  {% endif %}

  {# =========================================================
     WORKFLOW BODY — lanes column + optional side column
     ========================================================= #}
  {% set _has_side = (side is defined and side) %}
  <div class="workflow-body {% if _has_side %}with-side{% endif %}">
    <div class="lanes-column">
      {% for lane in lanes %}
        {% set _color = (lane.color if lane.color is defined else 'slate') %}
        {% set _dir   = (lane.direction if lane.direction is defined else 'ltr') %}
        <div class="lane {{ _color }} {% if _dir == 'rtl' %}rtl{% endif %}">
          <div class="lane-title">
            {% if lane.icon is defined and lane.icon %}<span>{{ lane.icon }}</span>{% endif %}
            <span>{{ lane.title }}</span>
          </div>
          <div class="lane-nodes">
            {% for n in lane['nodes'] %}
              <div class="node">
                {% if n.icon is defined and n.icon %}<div class="node-icon">{{ n.icon }}</div>{% endif %}
                <div class="node-title">{{ n.title|safe }}</div>
                {% if n.sub is defined and n.sub %}<div class="node-sub">{{ n.sub|safe }}</div>{% endif %}
                {% if n.chips is defined and n.chips %}
                  {% for c in n.chips %}
                    <div class="node-chip {{ (c.kind if c.kind is defined else '') }}">
                      {% if c.icon is defined and c.icon %}<span class="chip-icon">{{ c.icon }}</span>{% endif %}
                      <span class="chip-text">{{ c.text|safe }}</span>
                    </div>
                  {% endfor %}
                {% endif %}
              </div>
              {% if not loop.last %}
                {% set _edge = (lane.edges[loop.index0] if lane.edges is defined and lane.edges|length > loop.index0 else none) %}
                <div class="arrow">
                  {% if _edge is not none and _edge.label is defined and _edge.label %}
                    <div class="arrow-label">{{ _edge.label|safe }}</div>
                  {% endif %}
                  <div class="arrow-line">{% if _dir == 'rtl' %}←{% else %}→{% endif %}</div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
          {% if lane.tags is defined and lane.tags %}
            <div class="lane-footer">
              {% if lane.tag_label is defined and lane.tag_label %}
                <span class="lane-footer-label">{{ lane.tag_label }}</span>
              {% endif %}
              {% for t in lane.tags %}
                <span class="tag">{{ t }}</span>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if _has_side %}
    <div class="side-column">
      {% for box in side %}
        {% if box.type is defined and box.type == 'legend' %}
          <div class="legend-box">
            <div class="legend-title">{{ box.title }}</div>
            <div class="legend-items">
              {% for it in box['items'] %}
                <div class="legend-item {{ (it.kind if it.kind is defined else '') }}">
                  <div class="legend-icon">{{ it.icon }}</div>
                  <div>{{ it.text|safe }}</div>
                </div>
              {% endfor %}
            </div>
          </div>
        {% else %}
          {% set _bc = (box.color if box.color is defined else 'slate') %}
          <div class="info-box {{ _bc }}">
            <div class="info-title">{{ box.title }}</div>
            <div class="info-items">
              {% for it in box['items'] %}
                <div class="info-item">
                  <div class="info-item-icon">{{ (it.icon if it.icon is defined else '•') }}</div>
                  <div class="info-item-body">
                    <div class="info-item-title">{{ it.title|safe }}</div>
                    {% if it.sub is defined and it.sub %}<div class="info-item-sub">{{ it.sub|safe }}</div>{% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}
  </div>

  {# =========================================================
     SOURCES
     ========================================================= #}
  {% if sources is defined and sources %}
  <div class="section sources">
    <div class="section-head">
      <div class="section-icon">📚</div>
      <div>
        <div class="section-title">Sources</div>
        <div class="section-sub">Every lane and node above traces back to one of these first-hand references</div>
      </div>
    </div>
    <div class="sources-groups">
      {% for group in sources %}
      <div class="sources-group">
        <div class="sources-group-title">{{ group.title }}</div>
        {% for item in group['items'] %}
        <div class="source-item">
          • <b>{{ item.title }}</b>{% if item.meta is defined and item.meta %}<span class="meta"> — {{ item.meta }}</span>{% endif %}
        </div>
        {% endfor %}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# =========================================================
     CONFIDENCE
     ========================================================= #}
  {% if confidence is defined and confidence %}
  <div class="section confidence">
    <div class="section-head">
      <div class="section-icon">📊</div>
      <div>
        <div class="section-title">Confidence</div>
        <div class="section-sub">Calibrated to the evidence — one first-hand source caps at Medium</div>
      </div>
    </div>
    <div class="conf-card">
      <span class="conf-level {{ confidence.level|lower }}">{{ confidence.level }}</span>
      <div class="conf-detail">
        {% if confidence.verified is defined and confidence.verified %}<b>Verified:</b> {{ confidence.verified|safe }}{% endif %}
        {% if confidence.not_verified is defined and confidence.not_verified %}
          <span class="not-verified"><b>Not verified:</b> {{ confidence.not_verified|safe }}</span>
        {% endif %}
      </div>
    </div>
  </div>
  {% endif %}

  {# =========================================================
     FOR YOU
     ========================================================= #}
  {% if for_you is defined and for_you %}
  <div class="section foryou">
    <div class="section-head">
      <div class="section-icon">✅</div>
      <div>
        <div class="section-title">For you (next steps)</div>
        <div class="section-sub">Something concrete you can do without a follow-up</div>
      </div>
    </div>
    <div class="foryou-list">
      {% for item in for_you %}
        {% set _kind = (item.kind if item.kind is defined else 'lookup') %}
        <div class="foryou-item {% if _kind == 'recommend' %}recommend{% endif %}">
          <div class="foryou-check">{% if _kind == 'recommend' %}★{% else %}✓{% endif %}</div>
          <div class="foryou-text">{{ item.text|safe }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="footer">
    <div class="brand"><span class="brand-dot"></span>ProdOps Bot · Abacus Insights · knowledge_query · workflow</div>
    <div>Generated {{ generated_at }}</div>
  </div>

</div>
</body>
</html>
