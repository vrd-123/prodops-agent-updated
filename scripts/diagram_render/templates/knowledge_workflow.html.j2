<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>{{ title }}</title>
<style>
  :root {
    --bg: #F5F7FB;
    --card: #FFFFFF;
    --ink: #0F1B2E;
    --ink-soft: #4C5A72;
    --ink-mute: #7A8699;
    --border: #E4E9F2;
    --shadow: 0 2px 4px rgba(15,27,46,.04), 0 8px 24px rgba(15,27,46,.06);
    --blue: #2563EB;   --blue-bg: #DBEAFE;
    --indigo: #4F46E5; --indigo-bg: #EEF2FF;
    --green: #16A34A;  --green-bg: #DCFCE7;
    --amber: #D97706;  --amber-bg: #FEF3C7;
    --purple: #7C3AED; --purple-bg: #EDE9FE;
    --teal: #0D9488;   --teal-bg: #CCFBF1;
    --slate: #475569;  --slate-bg: #E2E8F0;
    --rose: #E11D48;   --rose-bg: #FFE4E6;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg); color: var(--ink);
    -webkit-font-smoothing: antialiased;
  }
  .page { width: 1200px; padding: 40px; }

  .header {
    background: var(--card); border: 1px solid var(--border); border-radius: 16px;
    padding: 24px 28px; box-shadow: var(--shadow); margin-bottom: 20px;
  }
  .header-top { display: flex; align-items: center; gap: 16px; margin-bottom: 12px; }
  .header-icon {
    width: 52px; height: 52px; border-radius: 12px;
    background: linear-gradient(135deg, #1D4ED8 0%, #4F46E5 100%);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 26px; flex-shrink: 0;
  }
  .header-title { font-size: 22px; font-weight: 700; color: var(--ink); }
  .header-sub { font-size: 13px; color: var(--ink-mute); margin-top: 2px; }
  .tldr {
    font-size: 15px; color: var(--ink-soft); line-height: 1.55;
    padding: 14px 16px; background: var(--indigo-bg); border-radius: 10px;
    border-left: 4px solid var(--indigo);
  }
  .tldr b { color: var(--ink); }

  .layout { display: grid; grid-template-columns: 1fr 280px; gap: 20px; }
  .lanes { display: flex; flex-direction: column; gap: 16px; }

  .lane {
    background: var(--card); border: 1px solid var(--border); border-radius: 14px;
    padding: 18px 20px; box-shadow: var(--shadow);
  }
  .lane-head {
    display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
    padding-bottom: 10px; border-bottom: 1px solid var(--border);
  }
  .lane-tag {
    font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
    padding: 4px 8px; border-radius: 6px;
  }
  .lane-title { font-size: 15px; font-weight: 700; color: var(--ink); }
  .lane.lane-router .lane-tag { background: var(--purple-bg); color: var(--purple); }
  .lane.lane-ticket .lane-tag { background: var(--blue-bg); color: var(--blue); }
  .lane.lane-knowledge .lane-tag { background: var(--teal-bg); color: var(--teal); }

  .flow { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
  .node {
    background: var(--slate-bg); border: 1px solid var(--border); border-radius: 10px;
    padding: 10px 12px; min-width: 110px; max-width: 160px; flex: 0 0 auto;
  }
  .node.router { background: var(--purple-bg); border-color: #C4B5FD; }
  .node.intake { background: var(--blue-bg); border-color: #93C5FD; }
  .node.subagent { background: var(--amber-bg); border-color: #FCD34D; }
  .node.output { background: var(--green-bg); border-color: #86EFAC; }
  .node.kstep { background: var(--teal-bg); border-color: #5EEAD4; }
  .node-num {
    font-size: 10px; font-weight: 700; color: var(--ink-mute); letter-spacing: .04em;
  }
  .node-label { font-size: 12px; font-weight: 700; color: var(--ink); margin-top: 2px; line-height: 1.3; }
  .node-detail { font-size: 10px; color: var(--ink-mute); margin-top: 4px; line-height: 1.35; }
  .arrow { color: var(--ink-mute); font-size: 18px; font-weight: 700; flex-shrink: 0; }

  .side { display: flex; flex-direction: column; gap: 14px; }
  .side-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 12px;
    padding: 14px 16px; box-shadow: var(--shadow);
  }
  .side-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--ink-mute); margin-bottom: 10px; }
  .side-item { font-size: 12px; color: var(--ink-soft); line-height: 1.45; margin-bottom: 6px; }
  .side-item:last-child { margin-bottom: 0; }
  .pill {
    display: inline-block; padding: 4px 10px; border-radius: 999px;
    font-size: 11px; font-weight: 600;
  }
  .pill.high { background: var(--green-bg); color: var(--green); }
  .pill.medium { background: var(--amber-bg); color: var(--amber); }
  .pill.low { background: var(--rose-bg); color: var(--rose); }

  .legend-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
  .legend-chip {
    display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--ink-soft);
  }
  .legend-dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }

  .sources { margin-top: 16px; }
  .source-group { margin-bottom: 8px; }
  .source-kind { font-size: 11px; font-weight: 700; color: var(--ink-mute); text-transform: uppercase; letter-spacing: .05em; }
  .source-item { font-size: 12px; color: var(--ink-soft); margin-top: 4px; line-height: 1.4; }

  .footer {
    margin-top: 16px; text-align: right; font-size: 11px; color: var(--ink-mute);
  }
</style>
</head>
<body>
<div class="page">
  <div class="header">
    <div class="header-top">
      <div class="header-icon">🤖</div>
      <div>
        <div class="header-title">{{ title }}</div>
        <div class="header-sub">{{ subtitle }}</div>
      </div>
    </div>
    <div class="tldr"><b>TL;DR:</b> {{ tldr|safe }}</div>
  </div>

  <div class="layout">
    <div class="lanes">
      {% for lane in lanes %}
      <div class="lane lane-{{ lane.id }}">
        <div class="lane-head">
          <span class="lane-tag">{{ lane.tag }}</span>
          <span class="lane-title">{{ lane.title }}</span>
        </div>
        <div class="flow">
          {% for node in lane.nodes %}
          {% if not loop.first %}<span class="arrow">→</span>{% endif %}
          <div class="node {{ node.style }}">
            {% if node.num is defined %}<div class="node-num">{{ node.num }}</div>{% endif %}
            <div class="node-label">{{ node.label|safe }}</div>
            {% if node.detail is defined %}<div class="node-detail">{{ node.detail|safe }}</div>{% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="side">
      <div class="side-card">
        <div class="side-title">Confidence</div>
        <span class="pill {{ confidence.level }}">{{ confidence.label }}</span>
        <div class="side-item" style="margin-top:8px;">{{ confidence.detail|safe }}</div>
      </div>

      <div class="side-card">
        <div class="side-title">Legend</div>
        <div class="legend-row">
          {% for item in legend %}
          <div class="legend-chip">
            <span class="legend-dot" style="background:{{ item.color }};"></span>
            {{ item.label }}
          </div>
          {% endfor %}
        </div>
      </div>

      <div class="side-card">
        <div class="side-title">For you</div>
        {% for tip in for_you %}
        <div class="side-item">• {{ tip|safe }}</div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="side-card sources">
    <div class="side-title">Sources</div>
    {% for group in sources %}
    <div class="source-group">
      <div class="source-kind">{{ group.kind }}</div>
      {% for ref in group.refs %}
      <div class="source-item">• {{ ref|safe }}</div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>

  <div class="footer">Generated {{ generated_at }}</div>
</div>
</body>
</html>
