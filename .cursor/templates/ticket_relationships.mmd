graph LR
    MAIN["🎫 {{TICKET_KEY}}<br/>{{TICKET_SUMMARY}}"]

    LINKED_1["{{LINKED_KEY_1}}<br/>{{LINKED_SUMMARY_1}}"]
    LINKED_2["{{LINKED_KEY_2}}<br/>{{LINKED_SUMMARY_2}}"]

    PERSON_1(("👤<br/>{{PERSON_1_NAME}}<br/>{{PERSON_1_ROLE}}"))
    PERSON_2(("👤<br/>{{PERSON_2_NAME}}<br/>{{PERSON_2_ROLE}}"))
    PERSON_3(("👤<br/>{{PERSON_3_NAME}}<br/>{{PERSON_3_ROLE}}"))

    LINKED_1 -->|"{{RELATION_1}}"| MAIN
    LINKED_2 -->|"{{RELATION_2}}"| MAIN
    MAIN --- PERSON_1
    MAIN --- PERSON_2
