    style MAIN fill:#0052CC,stroke:#003884,color:#fff
    style LINKED_1 fill:#DEEBFF,stroke:#0052CC,color:#172B4D
    style LINKED_2 fill:#DEEBFF,stroke:#0052CC,color:#172B4D
    style PERSON_1 fill:#F4F5F7,stroke:#6B778C,color:#172B4D
    style PERSON_2 fill:#F4F5F7,stroke:#6B778C,color:#172B4D
    style PERSON_3 fill:#F4F5F7,stroke:#6B778C,color:#172B4D